{
  "name": "repo2skill",
  "version": "0.1.0",
  "description": "Convert any GitHub repo into an OpenClaw skill. One command.",
  "main": "./dist/index.js",
  "bin": {
    "repo2skill": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "ts-node src/cli.ts",
    "test": "vitest run"
  },
  "author": "NeuZhou",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NeuZhou/repo2skill"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/__tests__/",
    "skill/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "openclaw",
    "skill",
    "github",
    "cli",
    "agent",
    "ai"
  ],
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "commander": "^12.1.0",
    "glob": "^11.0.0",
    "simple-git": "^3.27.0",
    "toml": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  }
}

